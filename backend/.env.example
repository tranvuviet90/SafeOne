# ----- Backend (Express) environment -----
# Copy to `backend/.env` and fill in real values. Never commit the real `.env`.

PORT=5000

# MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=safeone

# Secret used to sign JWT auth tokens. Use a long random string and keep it private.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# Google Gemini API key (only needed for the EHS AI chatbot features)
GOOGLE_APIKEY=

# ----- Password-reset email (SMTP) -----
# Used by the "Forgot password" flow to email a one-time reset link.
# If SMTP_HOST is empty, the reset link is printed to the server console instead
# of being emailed (handy for local development).
# Public base URL of the app, used to build the reset link (no trailing slash).
APP_BASE_URL=http://localhost:5000
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# "From" address shown on the reset email (defaults to SMTP_USER if empty).
SMTP_FROM=
