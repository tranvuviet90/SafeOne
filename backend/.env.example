# ===== Cấu hình Backend SafeOne =====
# Sao chép file này thành `backend/.env` rồi chỉ cần điền 3 dòng có dấu 👉 bên dưới.
# Các dòng còn lại đã để sẵn giá trị mặc định, KHÔNG cần sửa cho lần chạy thường.
# Lưu ý: KHÔNG commit file `backend/.env` thật lên GitHub.

# --- Đã để sẵn (chỉ sửa nếu MySQL của bạn cấu hình khác) ---
PORT=5000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_NAME=safeone

# 👉 (BẮT BUỘC) Mật khẩu của MySQL. Để trống nếu MySQL không đặt mật khẩu.
DB_PASSWORD=

# 👉 (BẮT BUỘC) Khóa ký token đăng nhập — dán một chuỗi ngẫu nhiên dài vào đây.
# Tạo chuỗi bằng lệnh:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# 👉 (TÙY CHỌN) API key Google Gemini — chỉ cần nếu dùng trợ lý AI. Để trống nếu chưa dùng.
GOOGLE_APIKEY=

# --- Email "Quên mật khẩu" (tùy chọn, để sẵn) ---
# Nếu SMTP_HOST để trống: link đặt lại mật khẩu sẽ được in ra console thay vì gửi email.
# APP_BASE_URL: địa chỉ public của app khi lên VPS (vd: http://ten-mien-cua-ban). Local cứ để mặc định.
APP_BASE_URL=http://localhost:5000
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
</content>
