# Mẫu backend/.env cho PRODUCTION — copy thành backend/.env trên VPS rồi điền giá trị.
# LƯU Ý: file .env thật KHÔNG được commit lên git.

PORT=5000

# ---- MySQL (đặt trên VPS) ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=safeone_user
DB_PASSWORD=doi-mat-khau-manh-o-day
DB_NAME=safeone

# ---- Bảo mật ----
# Khóa ký JWT. Sinh chuỗi ngẫu nhiên bằng:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# (Nếu bỏ trống, backend tự sinh và lưu ở backend/.jwt_secret — vẫn dùng được nhưng nên đặt chủ động.)
JWT_SECRET=

# Danh sách origin được phép gọi API (phân tách bằng dấu phẩy).
# BẮT BUỘC đặt trên production — bỏ trống nghĩa là mở cho mọi origin.
CORS_ORIGIN=https://safeone.example.com

# Địa chỉ gốc của app — dùng để tạo link trong email đặt lại mật khẩu.
APP_BASE_URL=https://safeone.example.com

# ---- AI Chatbot (Gemini) ----
GOOGLE_APIKEY=

# ---- Email đặt lại mật khẩu (SMTP) ----
# Chưa cấu hình thì tính năng "quên mật khẩu" chỉ in link ra log server (chế độ dev).
# Ví dụ Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=email, SMTP_PASS=app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SafeOne <no-reply@safeone.example.com>"
